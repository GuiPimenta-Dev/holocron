# One embedding provider key is required for `python -m ingest embed`:
OPENAI_API_KEY=          # uses text-embedding-3-small
# VOYAGE_API_KEY=        # uses voyage-3-lite

# Agent (phase 2):
ANTHROPIC_API_KEY=

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=holocron123

# Langfuse (self-hosted via docker compose). These keys are pre-provisioned by
# LANGFUSE_INIT_* in docker-compose.yml — the defaults below work as-is.
# UI: http://localhost:3001 (dev@holocron.local / holocron123)
LANGFUSE_PUBLIC_KEY=pk-lf-holocron-local
LANGFUSE_SECRET_KEY=sk-lf-holocron-local
LANGFUSE_HOST=http://localhost:3001
